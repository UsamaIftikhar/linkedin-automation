# Copy to .env — never commit .env

# /api/post auth: set in production (16+ chars). ?secret= or Authorization: Bearer
# POST_API_SECRET=

# /api/cron/daily-post (cron-jobs.org, etc.)
# CRON_SECRET=

# Buffer Publish GraphQL (required)
# BUFFER_GRAPHQL_URL=https://api.buffer.com/graphql
BUFFER_API_KEY=
BUFFER_CHANNEL_ID=

# Queued posts: due at now + N minutes (default 5). BUFFER_SCHEDULED_DUE_AT overrides (ISO 8601).
# BUFFER_SCHEDULE_OFFSET_MINUTES=5
# BUFFER_SCHEDULED_DUE_AT=

# BUFFER_GRAPHQL_SCHEDULING_TYPE=automatic
# BUFFER_GRAPHQL_POST_MODE=customSchedule

# Local only: append ISO timestamp so repeated /api/post tests skip Buffer duplicate checks. Do not use in production.
# APPEND_POST_NONCE=true

# Local only: allow pillar templates without DeepSeek (adds placeholder hashtags). Never use in production.
# ALLOW_TEMPLATE_PUBLISH=true

# LinkedIn / Buffer lint (LLM path). Defaults: 3000 chars, 90–180 word prose, 5–10 hashtags on final line(s).
# LINKEDIN_MAX_CHARS=3000
# POST_WORD_MIN=90
# POST_WORD_MAX=180
# POST_HASHTAG_MIN=5
# POST_HASHTAG_MAX=10

# Anti-repetition: last 10 (domain + postType) pairs on disk. Vercel: /tmp/linkedin-post-memory.json; local: data/post-memory.json
# POST_MEMORY_DISABLED=true
# POST_MEMORY_PATH=/path/to/post-memory.json

# DeepSeek (required for publishing). Default is `deepseek-chat` for lower token usage; switch to `deepseek-reasoner` only if you explicitly want reasoning mode.
DEEPSEEK_API_KEY=
# Supports `DeepseekAPIKey` too for compatibility, but prefer the uppercase name above.
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MAX_TOKENS=1500
# DEEPSEEK_MAX_ATTEMPTS=5
# DEEPSEEK_TEMPERATURE=1.5
# Note: DeepSeek thinking mode (`deepseek-reasoner`) ignores temperature and consumes far more output tokens.
# FORCE_TEMPLATE_ONLY=true
# DEEPSEEK_STRICT=true

# Default when /api/post has no ?now= / JSON body
# BUFFER_POST_NOW=false

# Optional: mirror post to your Ideas API after Buffer succeeds
# GRAPHQL_IDEAS_URL=
# GRAPHQL_IDEAS_TOKEN=
# IDEAS_ORGANIZATION_ID=
# GRAPHQL_IDEAS_AUTH_MODE=bearer
# SYNC_IDEA_TO_GRAPHQL=true
